{
  "info": {
    "name": "Go Gorée - API v1",
    "description": "Collection complète des workflows Go Gorée : authentification, comptes contrôleurs + réinitialisation de mot de passe, demandes de résidence, billetterie (portefeuille & PayDunya), scan, portefeuille, webhook PayDunya. Les tokens et identifiants sont capturés automatiquement dans les variables de collection.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "root_url", "value": "http://localhost:8000" },
    { "key": "base_url", "value": "{{root_url}}/api/v1" },
    { "key": "admin_email", "value": "admin@goree.sn" },
    { "key": "admin_password", "value": "Admin@1234" },
    { "key": "client_email", "value": "client@goree.sn" },
    { "key": "client_password", "value": "Client@1234" },
    { "key": "admin_token", "value": "" },
    { "key": "client_token", "value": "" },
    { "key": "controleur_token", "value": "" },
    { "key": "controleur_email", "value": "modou.controleur@goree.sn" },
    { "key": "reset_token", "value": "" },
    { "key": "demande_id", "value": "" },
    { "key": "voyage_id", "value": "" },
    { "key": "billet_id", "value": "" },
    { "key": "qr_token", "value": "" }
  ],
  "item": [
    {
      "name": "1. Authentification",
      "item": [
        {
          "name": "Login Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('admin_token', d.access_token);",
                  "pm.test('token admin reçu', () => pm.expect(d.access_token).to.be.a('string'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{admin_email}}\",\n  \"mot_de_passe\": \"{{admin_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Login Client",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('client_token', d.access_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{client_email}}\",\n  \"mot_de_passe\": \"{{client_password}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/login", "host": ["{{base_url}}"], "path": ["login"] }
          }
        },
        {
          "name": "Mon profil (me)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/me", "host": ["{{base_url}}"], "path": ["me"] }
          }
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/logout", "host": ["{{base_url}}"], "path": ["logout"] }
          }
        },
        {
          "name": "Mot de passe oublié",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{controleur_email}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/password/forgot", "host": ["{{base_url}}"], "path": ["password", "forgot"] }
          }
        },
        {
          "name": "Réinitialiser le mot de passe",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"{{controleur_email}}\",\n  \"token\": \"{{reset_token}}\",\n  \"mot_de_passe\": \"Controleur@1234\",\n  \"mot_de_passe_confirmation\": \"Controleur@1234\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/password/reset", "host": ["{{base_url}}"], "path": ["password", "reset"] }
          }
        }
      ]
    },
    {
      "name": "2. Utilisateurs & Contrôleurs (admin)",
      "item": [
        {
          "name": "Créer un contrôleur",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const d = pm.response.json().data;",
                  "pm.collectionVariables.set('controleur_email', d.email);",
                  "pm.test('role Agent', () => pm.expect(d.role.nom).to.eql('Agent'));"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prenom\": \"Modou\",\n  \"nom\": \"Fall\",\n  \"email\": \"modou.controleur@goree.sn\",\n  \"telephone\": \"770000000\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/controleurs", "host": ["{{base_url}}"], "path": ["controleurs"] }
          }
        },
        {
          "name": "Lister les contrôleurs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/controleurs", "host": ["{{base_url}}"], "path": ["controleurs"] }
          }
        },
        {
          "name": "Créer un utilisateur (générique)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"prenom\": \"Awa\",\n  \"nom\": \"Ndiaye\",\n  \"email\": \"awa.ndiaye@goree.sn\",\n  \"mot_de_passe\": \"Passer@1234\",\n  \"role_id\": \"<UUID_ROLE>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/users", "host": ["{{base_url}}"], "path": ["users"] }
          }
        }
      ]
    },
    {
      "name": "3. Demandes de résidence",
      "item": [
        {
          "name": "Soumettre une demande (client)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.collectionVariables.set('demande_id', pm.response.json().demande.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"carte_identite\": \"CNI123456789\",\n  \"residence\": \"Gorée Centre\",\n  \"photo\": \"photo_profil.png\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/demandes-residence", "host": ["{{base_url}}"], "path": ["demandes-residence"] }
          }
        },
        {
          "name": "Lister les demandes (admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/demandes-residence", "host": ["{{base_url}}"], "path": ["demandes-residence"] }
          }
        },
        {
          "name": "Valider une demande (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/demandes-residence/{{demande_id}}/valider", "host": ["{{base_url}}"], "path": ["demandes-residence", "{{demande_id}}", "valider"] }
          }
        },
        {
          "name": "Refuser une demande (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motif_refus\": \"Justificatifs illisibles.\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/demandes-residence/{{demande_id}}/refuser", "host": ["{{base_url}}"], "path": ["demandes-residence", "{{demande_id}}", "refuser"] }
          }
        }
      ]
    },
    {
      "name": "4. Voyages & Tarifs",
      "item": [
        {
          "name": "Lister les voyages",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const rows = pm.response.json().data;",
                  "if (rows && rows.length) pm.collectionVariables.set('voyage_id', rows[0].id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/voyages", "host": ["{{base_url}}"], "path": ["voyages"] }
          }
        },
        {
          "name": "Lister les tarifs",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/tarifs", "host": ["{{base_url}}"], "path": ["tarifs"] }
          }
        },
        {
          "name": "Créer un voyage (admin)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"date_voyage\": \"2026-07-20\",\n  \"places\": 150,\n  \"places_restantes\": 150,\n  \"trajet_id\": \"<UUID_TRAJET>\",\n  \"chaloupe_id\": \"<UUID_CHALOUPE>\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/voyages", "host": ["{{base_url}}"], "path": ["voyages"] }
          }
        }
      ]
    },
    {
      "name": "5. Billetterie & Scan",
      "item": [
        {
          "name": "Acheter un billet - Portefeuille",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const b = pm.response.json().billet;",
                  "pm.collectionVariables.set('billet_id', b.id);",
                  "pm.collectionVariables.set('qr_token', b.qr_token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"voyage_id\": \"{{voyage_id}}\",\n  \"payment_mode\": \"PORTEFEUILLE\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/billets", "host": ["{{base_url}}"], "path": ["billets"] }
          }
        },
        {
          "name": "Acheter un billet - PayDunya (lien de paiement)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "const r = pm.response.json();",
                  "console.log('Lien de paiement PayDunya : ' + r.redirect_url);",
                  "if (r.billet) pm.collectionVariables.set('billet_id', r.billet.id);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"voyage_id\": \"{{voyage_id}}\",\n  \"payment_mode\": \"PAYDUNYA\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/billets", "host": ["{{base_url}}"], "path": ["billets"] }
          }
        },
        {
          "name": "Lister mes billets",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/billets", "host": ["{{base_url}}"], "path": ["billets"] }
          }
        },
        {
          "name": "Détails d'un billet",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/billets/{{billet_id}}", "host": ["{{base_url}}"], "path": ["billets", "{{billet_id}}"] }
          }
        },
        {
          "name": "Scanner un billet (contrôleur)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{controleur_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"qr_token\": \"{{qr_token}}\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/scans", "host": ["{{base_url}}"], "path": ["scans"] }
          }
        }
      ]
    },
    {
      "name": "6. Portefeuille",
      "item": [
        {
          "name": "Voir mon portefeuille",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/portefeuille", "host": ["{{base_url}}"], "path": ["portefeuille"] }
          }
        },
        {
          "name": "Recharger - PayDunya (lien de paiement)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "console.log('Lien de recharge PayDunya : ' + pm.response.json().redirect_url);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"montant\": 5000,\n  \"payment_mode\": \"PAYDUNYA\"\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{base_url}}/portefeuille/recharge", "host": ["{{base_url}}"], "path": ["portefeuille", "recharge"] }
          }
        }
      ]
    },
    {
      "name": "7. Webhook PayDunya (simulation mode fake)",
      "item": [
        {
          "name": "Notifier le webhook",
          "request": {
            "method": "POST",
            "header": [{ "key": "Accept", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"data\": {\n    \"hash\": \"<SHA512_DU_SECRET>\",\n    \"status\": \"completed\",\n    \"invoice\": { \"token\": \"<PAYDUNYA_TOKEN>\" }\n  }\n}",
              "options": { "raw": { "language": "json" } }
            },
            "url": { "raw": "{{root_url}}/webhooks/paydunya", "host": ["{{root_url}}"], "path": ["webhooks", "paydunya"] }
          }
        }
      ]
    },
    {
      "name": "8. Notifications & Fraude",
      "item": [
        {
          "name": "Mes notifications",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{client_token}}" }
            ],
            "url": { "raw": "{{base_url}}/notifications", "host": ["{{base_url}}"], "path": ["notifications"] }
          }
        },
        {
          "name": "Alertes de fraude (admin)",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" },
              { "key": "Authorization", "value": "Bearer {{admin_token}}" }
            ],
            "url": { "raw": "{{base_url}}/alertes-fraude", "host": ["{{base_url}}"], "path": ["alertes-fraude"] }
          }
        }
      ]
    }
  ]
}
